{
  "name": "denali-js",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "napi": {
    "binaryName": "denali-js",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --output-dir dist --platform --release",
    "build:debug": "napi build --output-dir dist --platform",
    "version": "napi version",
    "test": "tsx --test 'e2e-test/**/*.test.ts'"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.5.0",
    "jose": "^6.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
