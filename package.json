{
  "name": "lonesome-js",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/K024/lonesome-js"
  },
  "keywords": [
    "serverless",
    "reverse-proxy",
    "pingora"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "napi": {
    "binaryName": "lonesome-js",
    "packageName": "@lonesome-js/binding",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "files": [
    "docs/",
    "dist/"
  ],
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --esm --output-dir dist --platform --release",
    "build:debug": "napi build --esm --output-dir dist --platform",
    "bench:list-suites": "tsx bench/index.ts list-suites",
    "bench:setup": "tsx bench/setup.ts start",
    "bench": "tsx bench/index.ts run",
    "version": "napi version",
    "lint": "tsc -b --noEmit",
    "test": "tsx --test 'e2e-test/**/*.test.ts'"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.5.2",
    "jose": "^6.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  }
}